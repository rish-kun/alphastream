# ===========================================
# AlphaStream India - Environment Variables
# ===========================================
# Copy this file to .env and fill in your values

# ---------- Database ----------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/alphastream
# Note: Port 5433 maps to container's 5432

# ---------- Redis ----------
REDIS_URL=redis://localhost:6380/0
# Note: Port 6380 maps to container's 6379

# ---------- Backend ----------
SECRET_KEY=change-me-to-a-random-secret-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------- OAuth (optional) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---------- AI / LLM APIs ----------
# Comma-separated list of API keys for rotation
GEMINI_API_KEYS=
OPENROUTER_API_KEYS=

# ---------- Reddit API ----------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=AlphaStream/0.1

# ---------- Frontend ----------
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1

# ---------- Pipeline ----------
FINBERT_MODEL=ProsusAI/finbert
SPACY_MODEL=en_core_web_sm
LLM_REQUESTS_PER_MINUTE=15
SCRAPE_TIMEOUT=30
MAX_ARTICLES_PER_FEED=50
SENTIMENT_FINBERT_MODEL=ProsusAI/finbert
SENTIMENT_GEMINI_MODEL=gemini-2.0-flash
SENTIMENT_OPENROUTER_MODEL=google/gemini-2.0-flash-001
SENTIMENT_LLM_PROVIDER_ORDER=gemini,openrouter
SENTIMENT_FINBERT_MAX_CHARS=3000
SENTIMENT_FINBERT_MAX_CHUNKS=3
SENTIMENT_LLM_MAX_CHARS=2200
SENTIMENT_LLM_TRIGGER_CONFIDENCE=0.70
SENTIMENT_LLM_TRIGGER_NEUTRAL_BAND=0.20
SENTIMENT_LOCAL_WEIGHT=0.65
SENTIMENT_LLM_WEIGHT=0.35
SENTIMENT_ENABLE_LLM=true
SENTIMENT_PENDING_BATCH_SIZE=50
SENTIMENT_REANALYZE_BATCH_LIMIT=100

# ---------- Extensive Research APIs ----------
FIRECRAWL_API_KEY=
BROWSEAI_API_KEY=
BROWSEAI_TEAM_ID=
BROWSEAI_DEFAULT_ROBOT_ID=
THUNDERBIT_API_KEY=
